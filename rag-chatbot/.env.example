APP_NAME=Personal RAG Chatbot
ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_DIR=./data

# Leave empty to use the offline extractive answerer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local deterministic embeddings keep the project runnable without paid APIs.
EMBEDDING_BACKEND=hash
EMBEDDING_DIMENSION=384

# CORS for local frontend development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
